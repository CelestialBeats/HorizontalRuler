<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="HorizontalRuler">
        <attr name="minValue" format="float"/>
        <attr name="maxValue" format="float"/>
        <attr name="initialValue" format="float"/>
        <attr name="tickColor" format="color"/>
        <attr name="indicatorColor" format="color"/>
        <attr name="rulerBackgroundColor" format="color"/>
        <attr name="edgeColor" format="color"/>
        <attr name="tickSpacing" format="dimension"/>
        <attr name="majorTickHeight" format="dimension"/>
        <attr name="mediumTickHeight" format="dimension"/>
        <attr name="minorTickHeight" format="dimension"/>
        <attr name="tickStrokeWidth" format="dimension"/>
        <attr name="indicatorWidth" format="dimension"/>
        <attr name="indicatorHeight" format="dimension"/>
        <attr name="baselineStrokeWidth" format="dimension"/>
        <attr name="edgeStrokeWidth" format="dimension"/>
        <attr name="baselinePaddingBottom" format="dimension"/>
        <attr name="edgeInset" format="dimension"/>
        <attr name="valueStep" format="float"/>
        <attr name="minorTicksPerMajor" format="integer"/>
        <attr name="snapAnimationDurationMs" format="integer"/>
        <attr name="showBaseline" format="boolean"/>
        <attr name="showEdges" format="boolean"/>
        <attr name="flingEnabled" format="boolean"/>
    </declare-styleable>
</resources>
